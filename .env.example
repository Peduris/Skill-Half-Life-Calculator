# --- Kickresume acquisition destinations (UTMs added automatically) ---
NEXT_PUBLIC_SIGNUP_URL="https://www.kickresume.com/register/"
NEXT_PUBLIC_CREATE_RESUME_URL="https://www.kickresume.com/dashboard/create-resume/"
NEXT_PUBLIC_CAREER_MAP_URL="https://www.kickresume.com/en/ai-career-map/"
NEXT_PUBLIC_CV_REBUILD_URL="https://www.kickresume.com/en/ai-career-map/"
NEXT_PUBLIC_RESUME_CHECKER_URL="https://www.kickresume.com/en/resume-checker/"
NEXT_PUBLIC_RESUME_TAILORING_URL="https://www.kickresume.com/en/resume-tailoring/"
NEXT_PUBLIC_JOB_BOARD_URL="https://www.kickresume.com/jobs/"

# Public site URL (share card + OG tags). No trailing slash.
NEXT_PUBLIC_SITE_URL="https://skill-half-life-calculator.vercel.app"

# --- Optional LLM via Vercel AI Gateway (one-liners + CV skill extraction) ---
# No OpenAI key needed. On Vercel, auth is automatic via OIDC — just enable AI
# Gateway in the project settings. If unset/unavailable, the app falls back to
# deterministic templates + keyword CV scanning.
#
# Local dev: run `vercel env pull .env.local` to provision VERCEL_OIDC_TOKEN,
# OR set a static AI_GATEWAY_API_KEY below (useful for CI / non-Vercel hosts).
AI_GATEWAY_API_KEY=""
# Model routed through the gateway (provider/model format; dots for versions).
# Default is cheap + fast + free-tier friendly. Premium models like
# "openai/gpt-5.4" are rate-limited on the free tier (add credits to use them).
AI_GATEWAY_MODEL="anthropic/claude-haiku-4.5"

# --- Optional Lightcast Skills API (progressive enhancement, not required) ---
# Free tier requires a registration form + email verification -> Client ID/Secret.
# See data/sources.csv for the exact docs URL. App ships fully working without this.
LIGHTCAST_CLIENT_ID=""
LIGHTCAST_CLIENT_SECRET=""

# --- Optional analytics passthrough ---
# If set, self-rolled events are ALSO forwarded to a Plausible-compatible endpoint.
# Leave empty to only log events server-side.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
